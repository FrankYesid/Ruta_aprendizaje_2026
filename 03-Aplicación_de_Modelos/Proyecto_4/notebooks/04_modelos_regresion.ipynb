   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Análisis de Residuos del Mejor Modelo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Obtener predicciones del mejor modelo\n",
    "best_model_map = {\n",
    "    'Linear_Simple': (lr_simple, X_train_simple, X_test_simple, y_train_pred_simple, y_test_pred_simple),\n",
    "    'Linear_Multiple': (lr_multi, X_train, X_test, y_train_pred_multi, y_test_pred_multi),\n",
    "    'Ridge': (ridge_best, X_train, X_test, y_train_pred_ridge, y_test_pred_ridge),\n",
    "    'Lasso': (lasso_best, X_train, X_test, y_train_pred_lasso, y_test_pred_lasso),\n",
    "    'Elastic_Net': (elastic_best, X_train, X_test, y_train_pred_elastic, y_test_pred_elastic)\n",
    "}\n",
    "\n",
    "best_model_obj, best_X_train, best_X_test, best_y_train_pred, best_y_test_pred = best_model_map[best_model_name]\n",
    "\n",
    "# Calcular residuos\n",
    "train_residuals = y_train - best_y_train_pred\n",
    "test_residuals = y_test - best_y_test_pred\n",
    "\n",
    "# Visualizar análisis de residuos\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n",
    "\n",
    "# Residuos vs predicciones (Train)\n",
    "axes[0, 0].scatter(best_y_train_pred, train_residuals, alpha=0.6)\n",
    "axes[0, 0].axhline(y=0, color='r', linestyle='--')\n",
    "axes[0, 0].set_xlabel('Predicciones')\n",
    "axes[0, 0].set_ylabel('Residuos')\n",
    "axes[0, 0].set_title(f'Residuos vs Predicciones - Train ({best_model_name})')\n",
    "\n",
    "# Residuos vs predicciones (Test)\n",
    "axes[0, 1].scatter(best_y_test_pred, test_residuals, alpha=0.6)\n",
    "axes[0, 1].axhline(y=0, color='r', linestyle='--')\n",
    "axes[0, 1].set_xlabel('Predicciones')\n",
    "axes[0, 1].set_ylabel('Residuos')\n",
    "axes[0, 1].set_title(f'Residuos vs Predicciones - Test ({best_model_name})')\n",
    "\n",
    "# Histograma de residuos (Train)\n",
    "axes[1, 0].hist(train_residuals, bins=30, alpha=0.7, edgecolor='black')\n",
    "axes[1, 0].set_xlabel('Residuos')\n",
    "axes[1, 0].set_ylabel('Frecuencia')\n",
    "axes[1, 0].set_title(f'Distribución de Residuos - Train ({best_model_name})')\n",
    "\n",
    "# Q-Q plot de residuos (Test)\n",
    "from scipy import stats\n",
    "stats.probplot(test_residuals, dist=\"norm\", plot=axes[1, 1])\n",
    "axes[1, 1].set_title(f'Q-Q Plot Residuos - Test ({best_model_name})')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Estadísticas de residuos\n",
    "print(f\"=== ESTADÍSTICAS DE RESIDUOS - {best_model_name} ===\")\n",
    "print(f\"Train - Media: {train_residuals.mean():.4f}, Std: {train_residuals.std():.4f}\")\n",
    "print(f\"Test - Media: {test_residuals.mean():.4f}, Std: {test_residuals.std():.4f}\")\n",
    "\n",
    "# Test de normalidad en residuos\n",
    "from scipy.stats import shapiro\n",
    "_, p_value_train = shapiro(train_residuals)\n",
    "_, p_value_test = shapiro(test_residuals)\n",
    "print(f\"Normalidad residuos train: p = {p_value_train:.4f}\")\n",
    "print(f\"Normalidad residuos test: p = {p_value_test:.4f}\")"
   ]
  },
  {
