{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04. Modelos de Regresión Lineal\n",
    "\n",
    "Este notebook implementa y compara diferentes modelos de regresión lineal para predecir precios de viviendas.\n",
    "\n",
    "## Objetivos\n",
    "- Implementar regresión lineal simple y múltiple\n",
    "- Aplicar regularización (Ridge, Lasso, Elastic Net)\n",
    "- Evaluar y comparar modelos lineales\n",
    "- Analizar importancia de características\n",
    "- Optimizar hiperparámetros"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Importación de librerías\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.linear_model import LinearRegression, Ridge, Lasso, ElasticNet\n",
    "from sklearn.model_selection import GridSearchCV, cross_val_score\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n",
    "from sklearn.pipeline import Pipeline\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Configuración\n",
    "plt.style.use('seaborn-v0_8')\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar datos procesados\n",
    "X_train = pd.read_csv('../data/X_train.csv')\n",
    "X_test = pd.read_csv('../data/X_test.csv')\n",
    "y_train = pd.read_csv('../data/y_train.csv').squeeze()\n",
    "y_test = pd.read_csv('../data/y_test.csv').squeeze()\n",
    "\n",
    "print(f\"Datos cargados:\")\n",
    "print(f\"X_train: {X_train.shape}\")\n",
    "print(f\"X_test: {X_test.shape}\")\n",
    "print(f\"y_train: {y_train.shape}\")\n",
    "print(f\"y_test: {y_test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Funciones de Evaluación"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Función para evaluar modelos\n",
    "def evaluate_model(model, X_train, X_test, y_train, y_test, model_name):\n",
    "    \"\"\"\n",
    "    Evalúa un modelo de regresión y retorna métricas\n",
    "    \"\"\"\n",
    "    # Predicciones\n",
    "    y_train_pred = model.predict(X_train)\n",
    "    y_test_pred = model.predict(X_test)\n",
    "    \n",
    "    # Métricas\n",
    "    train_mse = mean_squared_error(y_train, y_train_pred)\n",
    "    test_mse = mean_squared_error(y_test, y_test_pred)\n",
    "    train_rmse = np.sqrt(train_mse)\n",
    "    test_rmse = np.sqrt(test_mse)\n",
    "    train_mae = mean_absolute_error(y_train, y_train_pred)\n",
    "    test_mae = mean_absolute_error(y_test, y_test_pred)\n",
    "    train_r2 = r2_score(y_train, y_train_pred)\n",
    "    test_r2 = r2_score(y_test, y_test_pred)\n",
    "    \n",
    "    # Cross-validation\n",
    "    cv_scores = cross_val_score(model, X_train, y_train, cv=5, scoring='r2')\n",
    "    cv_r2_mean = cv_scores.mean()\n",
    "    cv_r2_std = cv_scores.std()\n",
    "    \n",
    "    # Crear dataframe de resultados\n",
    "    results = {\n",
    "        'Model': model_name,\n",
    "        'Train_RMSE': train_rmse,\n",
    "        'Test_RMSE': test_rmse,\n",
    "        'Train_MAE': train_mae,\n",
    "        'Test_MAE': test_mae,\n",
    "        'Train_R2': train_r2,\n",
    "        'Test_R2': test_r2,\n",
    "        'CV_R2_Mean': cv_r2_mean,\n",
    "        'CV_R2_Std': cv_r2_std,\n",
    "        'Overfitting': train_r2 - test_r2\n",
    "    }\n",
    "    \n",
    "    return results, y_train_pred, y_test_pred\n",
    "\n",
    "# Función para visualizar predicciones vs reales\n",
    "def plot_predictions(y_true, y_pred, title, ax=None):\n",
    "    \"\"\"\n",
    "    Visualiza predicciones vs valores reales\n",
    "    \"\"\"\n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots(figsize=(8, 6))\n",
    "    \n",
    "    ax.scatter(y_true, y_pred, alpha=0.6)\n",
    "    ax.plot([y_true.min(), y_true.max()], [y_true.min(), y_true.max()], 'r--', lw=2)\n",
    "    ax.set_xlabel('Valores Reales')\n",
    "    ax.set_ylabel('Predicciones')\n",
    "    ax.set_title(title)\n",
    "    \n",
    "    # Calcular R²\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    ax.text(0.05, 0.95, f'R² = {r2:.3f}', transform=ax.transAxes, \n",
    "            verticalalignment='top', bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))\n",
    "    \n",
    "    return ax"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Regresión Lineal Simple"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Modelo 1: Regresión Lineal con la variable más correlacionada (LSTAT)\n",
    "print(\"=== REGRESIÓN LINEAL SIMPLE (LSTAT) ===\")\n",
    "\n",
    "# Crear modelo con solo LSTAT\n",
    "X_train_simple = X_train[['lstat']]\n",
    "X_test_simple = X_test[['lstat']]\n",
    "\n",
    "lr_simple = LinearRegression()\n",
    "lr_simple.fit(X_train_simple, y_train)\n",
    "\n",
    "# Evaluar\n",
    "results_simple, y_train_pred_simple, y_test_pred_simple = evaluate_model(\n",
    "    lr_simple, X_train_simple, X_test_simple, y_train, y_test, 'Linear_Simple'\n",
    ")\n",
    "\n",
    "# Mostrar resultados\n",
    "results_df = pd.DataFrame([results_simple])\n",
    "print(results_df.round(3))\n",
    "\n",
    "# Visualizar\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "plot_predictions(y_train, y_train_pred_simple, 'Train - Linear Simple', axes[0])\n",
    "plot_predictions(y_test, y_test_pred_simple, 'Test - Linear Simple', axes[1])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Ecuación del modelo\n",
    "print(f\"\\nEcuación del modelo: MEDV = {lr_simple.intercept_:.2f} + {lr_simple.coef_[0]:.2f} * LSTAT\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Regresión Lineal Múltiple"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Modelo 2: Regresión Lineal Múltiple con todas las características\n",
    "print(\"=== REGRESIÓN LINEAL MÚLTIPLE ===\")\n",
    "\n",
    "lr_multi = LinearRegression()\n",
    "lr_multi.fit(X_train, y_train)\n",
    "\n",
    "# Evaluar\n",
    "results_multi, y_train_pred_multi, y_test_pred_multi = evaluate_model(\n",
    "    lr_multi, X_train, X_test, y_train, y_test, 'Linear_Multiple'\n",
    ")\n",
    "\n",
    "# Mostrar resultados\n",
    "print(pd.DataFrame([results_multi]).round(3))\n",
    "\n",
    "# Visualizar\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "plot_predictions(y_train, y_train_pred_multi, 'Train - Linear Multiple', axes[0])\n",
    "plot_predictions(y_test, y_test_pred_multi, 'Test - Linear Multiple', axes[1])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Análisis de coeficientes\n",
    "feature_importance = pd.DataFrame({\n",
    "    'Feature': X_train.columns,\n",
    "    'Coefficient': lr_multi.coef_\n",
    "}).sort_values('Coefficient', key=abs, ascending=False)\n",
    "\n",
    "print(f\"\\nTop 10 características más importantes (por coeficiente):\")\n",
    "print(feature_importance.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Regresión Ridge (Regularización L2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [\n",
    "# Búsqueda de hiperparámetros para Ridge\n",
    "print(\"=== BÚSQUEDA DE HIPERPARÁMETROS - RIDGE ===\")\n",
    "\n",
    "ridge_params = {\n",
    "    'alpha': [0.1, 0.5, 1.0, 5.0, 10.0, 50.0, 100.0, 500.0, 1000.0]\n",
    "}\n",
    "\n",
    "ridge_grid = GridSearchCV(Ridge(), ridge_params, cv=5, scoring='r2', n_jobs=-1)\n",
    "ridge_grid.fit(X_train, y_train)\n",
    "\n",
    "print(f\"Mejor alpha: {ridge_grid.best_params_['alpha']}\")\n",
    "print(f\"Mejor R² CV: {ridge_grid.best_score_:.4f}\")\n",
    "\n",
    "# Entrenar modelo optimizado\n",
    "ridge_best = ridge_grid.best_estimator_\n",
    "\n",
    "# Evaluar\n",
    "results_ridge, y_train_pred_ridge, y_test_pred_ridge = evaluate_model(\n",
    "    ridge_best, X_train, X_test, y_train, y_test, 'Ridge'\n",
    ")\n",
    "\n",
    "print(f\"\\nResultados Ridge:\")\n",
    "print(pd.DataFrame([results_ridge]).round(3))\n",
    "\n",
    "# Visualizar\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "plot_predictions(y_train, y_train_pred_ridge, 'Train - Ridge', axes[0])\n",
    "plot_predictions(y_test, y_test_pred_ridge, 'Test - Ridge', axes[1])\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Regresión Lasso (Regularización L1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Búsqueda de hiperparámetros para Lasso\n",
    "print(\"=== BÚSQUEDA DE HIPERPARÁMETROS - LASSO ===\")\n",
    "\n",
    "lasso_params = {\n",
    "    'alpha': [0.001, 0.01, 0.1, 0.5, 1.0, 5.0, 10.0, 50.0, 100.0]\n",
    "}\n",
    "\n",
    "lasso_grid = GridSearchCV(Lasso(max_iter=10000), lasso_params, cv=5, scoring='r2', n_jobs=-1)\n",
    "lasso_grid.fit(X_train, y_train)\n",
    "\n",
    "print(f\"Mejor alpha: {lasso_grid.best_params_['alpha']}\")\n",
    "print(f\"Mejor R² CV: {lasso_grid.best_score_:.4f}\")\n",
    "\n",
    "# Entrenar modelo optimizado\n",
    "lasso_best = lasso_grid.best_estimator_\n",
    "\n",
    "# Evaluar\n",
    "results_lasso, y_train_pred_lasso, y_test_pred_lasso = evaluate_model(\n",
    "    lasso_best, X_train, X_test, y_train, y_test, 'Lasso'\n",
    ")\n",
    "\n",
    "print(f\"\\nResultados Lasso:\")\n",
    "print(pd.DataFrame([results_lasso]).round(3))\n",
    "\n",
    "# Visualizar\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "plot_predictions(y_train, y_train_pred_lasso, 'Train - Lasso', axes[0])\n",
    "plot_predictions(y_test, y_test_pred_lasso, 'Test - Lasso', axes[1])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Análisis de coeficientes (feature selection)\n",
    "lasso_coef = pd.DataFrame({\n",
    "    'Feature': X_train.columns,\n",
    "    'Coefficient': lasso_best.coef_\n",
    "}).sort_values('Coefficient', key=abs, ascending=False)\n",
    "\n",
    "# Características seleccionadas (coeficiente != 0)\n",
    "selected_features = lasso_coef[lasso_coef['Coefficient'] != 0]\n",
    "print(f\"\\nCaracterísticas seleccionadas por Lasso: {len(selected_features)}\")\n",
    "print(selected_features.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Elastic Net (Regularización L1 + L2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Búsqueda de hiperparámetros para Elastic Net\n",
    "print(\"=== BÚSQUEDA DE HIPERPARÁMETROS - ELASTIC NET ===\")\n",
    "\n",
    "elastic_params = {\n",
    "    'alpha': [0.01, 0.1, 0.5, 1.0, 5.0, 10.0],\n",
    "    'l1_ratio': [0.1, 0.3, 0.5, 0.7, 0.9]\n",
    "}\n",
    "\n",
    "elastic_grid = GridSearchCV(ElasticNet(max_iter=10000), elastic_params, cv=5, scoring='r2', n_jobs=-1)\n",
    "elastic_grid.fit(X_train, y_train)\n",
    "\n",
    "print(f\"Mejores parámetros: {elastic_grid.best_params_}\")\n",
    "print(f\"Mejor R² CV: {elastic_grid.best_score_:.4f}\")\n",
    "\n",
    "# Entrenar modelo optimizado\n",
    "elastic_best = elastic_grid.best_estimator_\n",
    "\n",
    "# Evaluar\n",
    "results_elastic, y_train_pred_elastic, y_test_pred_elastic = evaluate_model(\n",
    "    elastic_best, X_train, X_test, y_train, y_test, 'Elastic_Net'\n",
    ")\n",
    "\n",
    "print(f\"\\nResultados Elastic Net:\")\n",
    "print(pd.DataFrame([results_elastic]).round(3))\n",
    "\n",
    "# Visualizar\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "plot_predictions(y_train, y_train_pred_elastic, 'Train - Elastic Net', axes[0])\n",
    "plot_predictions(y_test, y_test_pred_elastic, 'Test - Elastic Net', axes[1])\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Comparación de Modelos Lineales"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Recopilar todos los resultados\n",
    "all_results = [\n",
    "    results_simple, results_multi, results_ridge, \n",
    "    results_lasso, results_elastic\n",
    "]\n",
    "\n",
    "results_df = pd.DataFrame(all_results)\n",
    "print(\"=== COMPARACIÓN DE MODELOS LINEALES ===\")\n",
    "print(results_df.round(3))\n",
    "\n",
    "# Identificar mejor modelo\n",
    "best_model_idx = results_df['Test_R2'].idxmax()\n",
    "best_model_name = results_df.loc[best_model_idx, 'Model']\n",
    "print(f\"\\n🏆 Mejor modelo lineal: {best_model_name}\")\n",
    "print(f\"R² en test: {results_df.loc[best_model_idx, 'Test_R2']:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualizar comparación de métricas\n",
