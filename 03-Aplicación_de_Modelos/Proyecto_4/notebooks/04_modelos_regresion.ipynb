   "source": [
    "## 9. Guardar Modelos y Resultados"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Guardar resultados\n",
    "results_df.to_csv('../reports/linear_models_results.csv', index=False)\n",
    "\n",
