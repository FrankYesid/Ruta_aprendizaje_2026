 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 - Modelado de series temporales con ARIMA\n",
    "\n",
    "En este cuaderno se entrena y evalúa un modelo ARIMA sencillo para una serie de precios seleccionada del dataset financiero."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from statsmodels.tsa.arima.model import ARIMA\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Carga del dataset y preparación de la serie temporal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "csv_path = Path(\"..\") / \"data\" / \"financial_timeseries_dataset.csv\"\n",
    "df = pd.read_csv(csv_path)\n",
    "\n",
    "date_candidates = [c for c in df.columns if \"date\" in c.lower() or \"time\" in c.lower()]\n",
    "date_col = date_candidates[0]\n",
    "\n",
    "df[\"datetime\"] = pd.to_datetime(df[date_col], errors=\"coerce\")\n",
    "df = df.set_index(\"datetime\").sort_index()\n",
    "\n",
    "value_col = \"Close\" if \"Close\" in df.columns else df.select_dtypes(include=\"number\").columns[0]\n",
    "\n",
    "series = df[value_col].dropna()\n",
    "series.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## División entrenamiento / prueba respetando el tiempo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "split_idx = int(len(series) * 0.8)\n",
    "\n",
    "train = series.iloc[:split_idx]\n",
    "test = series.iloc[split_idx:]\n",
    "\n+    "train.tail(), test.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Entrenamiento de un modelo ARIMA básico"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = ARIMA(train, order=(5, 1, 0))\n",
    "model_fit = model.fit()\n",
    "model_fit.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Pronóstico sobre el conjunto de prueba y evaluación del modelo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "forecast = model_fit.forecast(steps=len(test))\n",
    "forecast.index = test.index\n",
    "\n",
    "mae = mean_absolute_error(test, forecast)\n",
    "rmse = mean_squared_error(test, forecast, squared=False)\n",
    "\n",
    "mae, rmse"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Comparación visual de la serie real y el pronóstico"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(12, 5))\n",
    "train.plot(label=\"Entrenamiento\")\n",
    "test.plot(label=\"Real (test)\")\n",
    "forecast.plot(label=\"Pronóstico ARIMA\")\n",
    "plt.ylabel(value_col)\n",
    "plt.title(\"Serie real vs pronóstico ARIMA\")\n",
    "plt.legend()\n",
    "plt.tight_layout()"
   ]
  }
 ],
